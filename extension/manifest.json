{
  "manifest_version": 3,
  "name": "ListBlitz — Cross-Platform Publishing",
  "version": "1.0.1",
  "description": "Publish listings to 8 marketplaces directly from ListBlitz: Depop, Grailed, Poshmark, Mercari, eBay, Vinted, Facebook Marketplace, and Vestiaire Collective.",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://*.depop.com/*",
    "https://*.grailed.com/*",
    "https://*.poshmark.com/*",
    "https://*.mercari.com/*",
    "https://*.ebay.com/*",
    "https://*.vinted.com/*",
    "https://*.vinted.fr/*",
    "https://*.vinted.de/*",
    "https://*.vinted.co.uk/*",
    "https://*.vinted.it/*",
    "https://*.vinted.es/*",
    "https://*.vinted.pl/*",
    "https://*.vinted.nl/*",
    "https://*.vinted.be/*",
    "https://*.vinted.pt/*",
    "https://*.vinted.lt/*",
    "https://*.facebook.com/*",
    "https://*.vestiairecollective.com/*",
    "https://listblitz.io/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.depop.com/*",
        "https://www.grailed.com/*",
        "https://www.poshmark.com/*",
        "https://www.mercari.com/*",
        "https://www.ebay.com/*",
        "https://www.vinted.com/*",
        "https://www.vinted.fr/*",
        "https://www.vinted.de/*",
        "https://www.vinted.co.uk/*",
        "https://www.vinted.it/*",
        "https://www.vinted.es/*",
        "https://www.vinted.pl/*",
        "https://www.facebook.com/*",
        "https://www.vestiairecollective.com/*",
        "https://us.vestiairecollective.com/*"
      ],
      "js": ["content/bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://listblitz.io/*",
        "http://localhost:3000/*"
      ],
      "js": ["content/app-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://listblitz.io/*",
      "http://localhost:3000/*"
    ]
  }
}
