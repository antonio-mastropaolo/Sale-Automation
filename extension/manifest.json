{
  "manifest_version": 3,
  "name": "ListBlitz — Cross-Platform Publishing",
  "version": "1.0.0",
  "description": "Publish listings to Depop, Grailed, Poshmark, Mercari, eBay, Vinted, Facebook Marketplace, and Vestiaire Collective directly from ListBlitz.",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.depop.com/*",
    "https://depop.com/*",
    "https://www.grailed.com/*",
    "https://grailed.com/*",
    "https://www.poshmark.com/*",
    "https://poshmark.com/*",
    "https://www.mercari.com/*",
    "https://mercari.com/*",
    "https://www.ebay.com/*",
    "https://ebay.com/*",
    "https://signin.ebay.com/*",
    "https://www.vinted.com/*",
    "https://vinted.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://www.vestiairecollective.com/*",
    "https://vestiairecollective.com/*",
    "https://listblitz.io/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.depop.com/*",
        "https://www.grailed.com/*",
        "https://www.poshmark.com/*",
        "https://www.mercari.com/*",
        "https://www.ebay.com/*",
        "https://www.vinted.com/*",
        "https://www.facebook.com/*",
        "https://www.vestiairecollective.com/*"
      ],
      "js": ["content/bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://listblitz.io/*",
        "http://localhost:3000/*"
      ],
      "js": ["content/app-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://listblitz.io/*",
      "http://localhost:3000/*"
    ]
  }
}
