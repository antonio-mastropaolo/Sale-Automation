generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  brand       String   @default("")
  size        String   @default("")
  condition   String   @default("Good")
  price       Float
  costPrice   Float    @default(0) // what the seller paid (COGS)
  status      String   @default("draft") // draft, active, sold
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images           ListingImage[]
  platformListings PlatformListing[]
  sales            Sale[]
  scheduledPosts   ScheduledPost[]
  conversations    Conversation[]
}

model ListingImage {
  id        String @id @default(uuid())
  listingId String
  path      String
  order     Int    @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model PlatformListing {
  id                   String    @id @default(uuid())
  listingId            String
  platform             String // depop, grailed, poshmark, mercari, ebay
  optimizedTitle       String
  optimizedDescription String
  hashtags             String    @default("") // JSON array stored as string
  suggestedPrice       Float?
  platformUrl          String?
  status               String    @default("draft") // draft, published, failed
  publishedAt          DateTime?
  createdAt            DateTime  @default(now())

  listing         Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  analyticsEvents AnalyticsEvent[]
}

model PlatformCredential {
  id            String   @id @default(uuid())
  platform      String   @unique
  encryptedData String   // AES-256 encrypted JSON
  authMethod    String   @default("credentials") // credentials, google, apple, facebook, web_session, api_key
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AnalyticsEvent {
  id                String   @id @default(uuid())
  platformListingId String
  eventType         String // view, like, offer, sale
  value             Float    @default(0)
  recordedAt        DateTime @default(now())

  platformListing PlatformListing @relation(fields: [platformListingId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String // JSON-encoded value
  updatedAt DateTime @updatedAt
}

model CustomPrompt {
  id         String   @id @default(uuid())
  featureKey String   @unique // e.g., "optimize", "smart_list", "price_intel"
  label      String
  prompt     String
  updatedAt  DateTime @updatedAt
}

// ── New models for automation hub ──────────────────────────────────

model Template {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("")
  brand       String   @default("")
  condition   String   @default("Good")
  description String   @default("")
  tags        String   @default("") // JSON array as string
  platforms   String   @default("") // JSON array of target platforms
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sale {
  id           String   @id @default(uuid())
  listingId    String?
  platform     String
  title        String
  soldPrice    Float
  costPrice    Float    @default(0)
  shippingCost Float    @default(0)
  platformFee  Float    @default(0)
  profit       Float    @default(0)
  buyerName    String   @default("")
  soldAt       DateTime @default(now())
  notes        String   @default("")

  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
}

model ScheduledPost {
  id          String    @id @default(uuid())
  listingId   String
  platform    String
  scheduledAt DateTime
  status      String    @default("pending") // pending, published, failed, cancelled
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ImportJob {
  id          String    @id @default(uuid())
  fileName    String
  totalRows   Int       @default(0)
  processed   Int       @default(0)
  errors      Int       @default(0)
  status      String    @default("pending") // pending, processing, completed, failed
  errorLog    String    @default("") // JSON array of error messages
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

// ── Activity log — app-level event tracking for ops monitor ─────────

model ActivityLog {
  id        String   @id @default(uuid())
  type      String   // listing_created, optimize, publish_success, publish_failed, etc.
  title     String   // Human-readable summary
  detail    String   @default("")
  platform  String   @default("")
  severity  String   @default("info") // info, success, warning, error
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
}

// ── Auth models ─────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  role         String    @default("user") // user, admin
  onboarded    Boolean   @default(false) // has completed onboarding wizard
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String    @id @default(uuid())
  platform      String    // depop, grailed, poshmark, mercari, ebay, vinted, facebook, vestiaire
  buyerName     String
  buyerUsername String    @default("")
  buyerAvatar   String    @default("")
  listingId     String?   // optional link to a listing
  listingTitle  String    @default("")
  status        String    @default("open") // open, closed, archived
  lastMessage   String    @default("")
  lastMessageAt DateTime  @default(now())
  unread        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages Message[]
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  sender         String   // "buyer" or "seller"
  content        String
  platform       String   // which platform this was sent on
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SupportMessage {
  id        String   @id @default(uuid())
  message   String
  page      String   @default("")
  createdAt DateTime @default(now())
}
