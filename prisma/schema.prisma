generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  brand       String   @default("")
  size        String   @default("")
  condition   String   @default("Good")
  price       Float
  status      String   @default("draft") // draft, active, sold
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images           ListingImage[]
  platformListings PlatformListing[]
}

model ListingImage {
  id        String @id @default(uuid())
  listingId String
  path      String
  order     Int    @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model PlatformListing {
  id                   String    @id @default(uuid())
  listingId            String
  platform             String // depop, grailed, poshmark, mercari
  optimizedTitle       String
  optimizedDescription String
  hashtags             String    @default("") // JSON array stored as string
  suggestedPrice       Float?
  platformUrl          String?
  status               String    @default("draft") // draft, published, failed
  publishedAt          DateTime?
  createdAt            DateTime  @default(now())

  listing         Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  analyticsEvents AnalyticsEvent[]
}

model PlatformCredential {
  id            String @id @default(uuid())
  platform      String @unique
  encryptedData String // AES-256 encrypted JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AnalyticsEvent {
  id                String   @id @default(uuid())
  platformListingId String
  eventType         String // view, like, offer, sale
  value             Float    @default(0)
  recordedAt        DateTime @default(now())

  platformListing PlatformListing @relation(fields: [platformListingId], references: [id], onDelete: Cascade)
}
